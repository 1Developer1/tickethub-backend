# TicketHub Environment Configuration
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql://tickethub:tickethub_secret@localhost:5432/tickethub?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-256-bit-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-min-256-bit-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# QR Ticket HMAC
TICKET_HMAC_SECRET=your-hmac-secret-min-256-bit-change-in-production

# Email (MailHog in development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tickethub.com

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
